local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")

local replicatedStorage = game:GetService("ReplicatedStorage")

local players = game:GetService("Players")
local localPlayer = players.LocalPlayer
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")

local partyZones = workspace:WaitForChild("PartyZones")
local remotes = replicatedStorage:WaitForChild("Shared"):WaitForChild("Universe"):WaitForChild("Network"):WaitForChild("RemoteEvent")
local createparty = remotes:WaitForChild("CreateParty")
local exitparty = remotes:WaitForChild("ExitParty")

local menu = localPlayer.PlayerGui:WaitForChild("PartyCreation"):WaitForChild("Frame")
local exit = localPlayer.PlayerGui:WaitForChild("ExitParty")
local isFound = false

local function Timeout(time)
	spawn(function()
		while task.wait(1) do
			time -= 1
			if time <= 0 then
				dataCFG["isFarm"] = false
				UpdateCFG(dataCFG)
				pcall(function()
					local sur, err = TeleportService:Teleport(116495829188952, LocalPlayer)
					task.wait(5)
				end)
			end
		end
	end)
end

local dataName = "DeadRailsCFG.json"
local function UpdateCFG(data)
	if not data then return end
	
	dataCFG = data
	return writefile(dataName, HttpService:JSONEncode(data))
end

menu:GetPropertyChangedSignal("Position"):Connect(function() 
	local args = {
		  [1] = {
	 	 ["isPrivate"] = true,
	 	 ["maxMembers"] = 1,
	   	 ["trainId"] = "default",
	   	 ["gameMode"] = "BiteSized"
	    }
	}
	createparty:FireServer(unpack(args))
	task.wait(1)
	if exit.Enabled then
		isFound = true
		dataCFG["isFarm"] = true
		UpdateCFG(dataCFG)
	else
		Scan()
	end
end)

local function Scan()
	if isFound then return end
	for index, lobby in pairs(partyZones:GetChildren()) do
		if isFound then break end

		local status = lobby.BillboardGui.StatusLabel
		local hitbox = lobby.Hitbox
		
		if status.Text == "Waiting for players..." then
			hrp.CFrame = lobby.Hitbox.CFrame
			task.wait(1)
			hrp.CFrame = CFrame.new(hitbox.CFrame.Position.X, hitbox.CFrame.Position.Y + 30, hitbox.Position.Z)
			
		end
		task.wait(1)
	end
	Scan()
end
Timeout(40)
Scan()
